{
  "name": "@davidorex/pi-custom-compactor",
  "version": "0.1.2",
  "description": "Declarative YAML-driven structured compaction for pi coding agent — multi-pass extraction, artifact persistence, budget management, and work-mode-specific compaction specs",
  "type": "module",
  "license": "MIT",
  "author": "David Ryan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidorex/pi-custom-compactor.git"
  },
  "homepage": "https://github.com/davidorex/pi-custom-compactor",
  "keywords": [
    "pi-package",
    "pi-extension",
    "compaction",
    "context-management",
    "coding-agent"
  ],
  "files": [
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "seeds/",
    "skills/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "generate-skills": "npx tsx scripts/generate-skills.ts",
    "release": "npx changelogen --bump --release",
    "release:patch": "npx changelogen --bump --release --patch",
    "release:minor": "npx changelogen --bump --release --minor",
    "release:major": "npx changelogen --bump --release --major",
    "release:push": "git push --follow-tags"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "yaml": "^2.7.1"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "typescript": "^5.9.3"
  }
}
